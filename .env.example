# ========================
# FlyerWise Configuration
# ========================

# Database
DATABASE_URL=postgresql://flyerwise_user:flyerwise_pass@localhost:5432/flyerwise_db
POSTGRES_DB=flyerwise_db
POSTGRES_USER=flyerwise_user
POSTGRES_PASSWORD=flyerwise_pass

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Scraper
DEFAULT_POSTAL_CODE=H4G 2Y5
HEADLESS_BROWSER=true
SCRAPE_INTERVAL_HOURS=168  # Weekly (7 days * 24 hours)

# Frontend
VITE_API_URL=http://localhost:8000/api
